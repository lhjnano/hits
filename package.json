{
  "name": "@purpleraven/hits",
  "version": "1.2.9",
  "description": "Your AI session died. Your work didn't. The checkpoint system for AI coding sessions — token limits, session swaps, tool switches, pick up where you left off.",
  "keywords": [
    "ai",
    "checkpoint",
    "session-resume",
    "token-limit",
    "mcp",
    "handover",
    "claude-code",
    "opencode",
    "cursor",
    "knowledge-management"
  ],
  "license": "Apache-2.0",
  "author": "HITS Team",
  "type": "module",
  "bin": {
    "hits": "bin/hits.js",
    "hits-mcp": "bin/hits-mcp.js"
  },
  "scripts": {
    "start": "node bin/hits.js",
    "dev": "node bin/hits.js --dev",
    "build": "cd hits_web && npm run build",
    "setup": "node bin/hits.js --setup",
    "postinstall": "node postinstall.cjs",
    "test": "cd hits_web && npm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "bin/",
    "server.js",
    "postinstall.js",
    "postinstall.cjs",
    "pyproject.toml",
    "hits_core/**/*.py",
    "hits_core/**/__init__.py",
    "!hits_core/**/__pycache__",
    "!hits_core/**/*.pyc",
    "!hits_core/**/*.pyo",
    "hits_web/dist/",
    "hooks/",
    "config/",
    "data/dev_handover.yaml",
    "docs/",
    "requirements.txt",
    "requirements-core.txt",
    "requirements-mcp.txt",
    "run.sh",
    "AGENTS.md"
  ],
  "dependencies": {
    "express": "^4.21.0",
    "http-proxy-middleware": "^3.0.0"
  },
  "main": "server.js",
  "directories": {
    "test": "tests"
  },
  "devDependencies": {},
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lhjnano/hits.git"
  },
  "bugs": {
    "url": "https://github.com/lhjnano/hits/issues"
  },
  "homepage": "https://github.com/lhjnano/hits#readme",
  "talkToUs": "https://github.com/lhjnano/hits/discussions"
}
